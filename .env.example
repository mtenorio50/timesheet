# Supabase — get these from your project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# VAPID keys — generate once with: npx web-push generate-vapid-keys
# NEVER regenerate after employees have subscribed — existing subscriptions will break
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@royalglass.co.nz

# Cron secret — used to authenticate requests to /api/notify/reminders
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here
